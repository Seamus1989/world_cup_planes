# --- Database: Neon Postgres ---------------------------------------------
# Create a free project at https://neon.tech, then copy the POOLED connection
# string (the one with "-pooler" in the host) from the dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"

# --- Auth.js (Google sign-in) --------------------------------------------
# Generate a secret with:  bunx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Google OAuth credentials (console.cloud.google.com → Credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- The Tannoy (needed at M3, not for local foundation) ------------------
# Vercel AI Gateway key for Claude-generated Slack copy
AI_GATEWAY_API_KEY=""
# Slack incoming webhook URL
SLACK_WEBHOOK_URL=""
